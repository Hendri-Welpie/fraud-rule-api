    {
      "name": "Rules API",
      "item": [
        {
          "name": "Create Rule",
          "item": [
            {
              "name": "Simple Rule (Amount > 1000)",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  },
                  {
                    "key": "X-Trace-Id",
                    "value": "{{trace_id}}"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"ruleId\": \"high-amount-rule\",\n  \"name\": \"High Amount Rule\",\n  \"description\": \"Flag transactions with amount > 1000\",\n  \"condition\": {\n    \"type\": \"GREATER_THAN\",\n    \"field\": \"amount\",\n    \"value\": 1000\n  },\n  \"actions\": [\n    {\n      \"type\": \"FLAG\",\n      \"severity\": \"MEDIUM\"\n    }\n  ],\n  \"enabled\": true\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/v1/rules",
                  "host": ["{{base_url}}"],
                  "path": ["api", "v1", "rules"]
                }
              },
              "response": []
            },
            {
              "name": "Complex Rule (AND condition)",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  },
                  {
                    "key": "X-Trace-Id",
                    "value": "{{trace_id}}"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"ruleId\": \"complex-rule\",\n  \"name\": \"Complex Rule\",\n  \"description\": \"High amount AND suspicious currency\",\n  \"condition\": {\n    \"type\": \"AND\",\n    \"operands\": [\n      {\n        \"type\": \"GREATER_THAN\",\n        \"field\": \"amount\",\n        \"value\": 50000\n      },\n      {\n        \"type\": \"EQUAL\",\n        \"field\": \"currency\",\n        \"value\": \"USD\"\n      }\n    ]\n  },\n  \"actions\": [\n    {\n      \"type\": \"FLAG\",\n      \"severity\": \"HIGH\"\n    }\n  ],\n  \"enabled\": true\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/v1/rules",
                  "host": ["{{base_url}}"],
                  "path": ["api", "v1", "rules"]
                }
              },
              "response": []
            },
